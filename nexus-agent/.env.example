# =============================================================================
# Nexus Agent — Environment Configuration
# =============================================================================
# All variables use the NEXUS_ prefix with __ as the nested group delimiter.
# Example: NEXUS_DATABASE__URL sets settings.database.url
#
# Load order: .env -> .env.local -> process env vars (later wins)
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
NEXUS_DATABASE__URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus
NEXUS_DATABASE__POOL_SIZE=10
NEXUS_DATABASE__MAX_OVERFLOW=20
NEXUS_DATABASE__ECHO_SQL=false
NEXUS_DATABASE__STATEMENT_TIMEOUT_MS=30000

# ── Redis ────────────────────────────────────────────────────────────────────
NEXUS_REDIS__URL=redis://localhost:6379/0
NEXUS_REDIS__DB=0
NEXUS_REDIS__MAX_CONNECTIONS=20
NEXUS_REDIS__SSL=false

# ── LLM ──────────────────────────────────────────────────────────────────────
NEXUS_LLM__DEFAULT_PROVIDER=openai
NEXUS_LLM__DEFAULT_MODEL=gpt-4o
NEXUS_LLM__TEMPERATURE=0.7
NEXUS_LLM__MAX_TOKENS=4096
NEXUS_LLM__TIMEOUT_S=60
NEXUS_LLM__MAX_RETRIES=3
# JSON array of provider configs (see docs for shape):
# NEXUS_LLM__PROVIDERS=[{"name":"openai","base_url":"","api_key_ref":"OPENAI_API_KEY","models":["gpt-4o","gpt-4o-mini","text-embedding-3-small"],"cost_per_1k_input":0.01,"cost_per_1k_output":0.03,"max_tokens":4096,"supports_streaming":true,"supports_tools":true,"supports_structured_output":true}]

# ── Tools / API ──────────────────────────────────────────────────────────────
NEXUS_TOOLS__EXECUTION_TIMEOUT_S=30
NEXUS_TOOLS__MAX_RETRIES=3
NEXUS_TOOLS__RETRY_BACKOFF_S=1.0
NEXUS_TOOLS__SANDBOX_ENABLED=true
# Allowed external hosts for tool HTTP calls (empty = block all).
# Add your tool API hosts as a JSON array, e.g.:
#   NEXUS_TOOLS__ALLOWED_HOSTS=["api.example.com","*.internal.com","api.github.com"]
NEXUS_TOOLS__ALLOWED_HOSTS=[]
NEXUS_TOOLS__HTTP2_ENABLED=true
# NEXUS_TOOLS__PROXY_URL=http://proxy:8080

# ── MCP ──────────────────────────────────────────────────────────────────────
NEXUS_MCP__DEFAULT_TIMEOUT_S=30
NEXUS_MCP__MAX_RETRIES=3

# ── Embed ────────────────────────────────────────────────────────────────────
NEXUS_EMBED__ENABLED=true
# Comma-separated list of allowed embed widget origins for CORS protection.
# Use "*" for development only. In production, list explicit domains:
#   NEXUS_EMBED__ALLOWED_ORIGINS=myapp.com,www.myapp.com
NEXUS_EMBED__ALLOWED_ORIGINS=*
NEXUS_EMBED__RATE_LIMIT=30
NEXUS_EMBED__ANALYTICS_ENABLED=true

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXUS_FRONTEND__API_URL=http://localhost:8000

# ── Auth / Security ──────────────────────────────────────────────────────────
# IMPORTANT: In production, set these via a secret manager (Vault/AWS SM).
# Never store real secrets in .env or .env.example.
NEXUS_AUTH__JWT_SECRET=change-me-to-a-strong-random-secret
NEXUS_AUTH__JWT_ALGORITHM=HS256
NEXUS_AUTH__ACCESS_TOKEN_TTL_MINUTES=30
NEXUS_AUTH__REFRESH_TOKEN_TTL_DAYS=7
NEXUS_AUTH__API_KEY_HEADER_NAME=X-API-Key
# NEXUS_CREDENTIAL_MASTER_KEY=set-a-32-byte-key-for-aes-256-gcm

# ── Agent ────────────────────────────────────────────────────────────────────
NEXUS_AGENT__MAX_ITERATIONS=25
NEXUS_AGENT__MAX_PLAN_STEPS=10
NEXUS_AGENT__CONTEXT_WINDOW_TOKENS=128000
NEXUS_AGENT__SUMMARIZATION_THRESHOLD_TOKENS=64000
NEXUS_AGENT__HITL_DEFAULT=true
# NEXUS_AGENT__HITL_TOOL_PATTERNS=["delete.*","update.*"]
# Lock TTL and heartbeat for per-session concurrency control
NEXUS_AGENT__RUN_LOCK_TTL_S=600
NEXUS_AGENT__MAX_SUB_ITERATIONS=5

# ── Server ───────────────────────────────────────────────────────────────────
NEXUS_SERVER__HOST=0.0.0.0
NEXUS_SERVER__PORT=8000
# Multi-worker (K8s) safe — all state lives in Postgres checkpointer
NEXUS_SERVER__WORKERS=4
# Dev frontend origins; set explicit origins in production (never ["*"])
NEXUS_SERVER__CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
NEXUS_SERVER__DOCS_URL=/docs

# ── Observability ────────────────────────────────────────────────────────────
# NEXUS_OBSERVABILITY__LANGSMITH_API_KEY=lsv2_...
NEXUS_OBSERVABILITY__LANGSMITH_PROJECT=nexus-agent
# NEXUS_OBSERVABILITY__OTEL_ENDPOINT=http://localhost:4318
NEXUS_OBSERVABILITY__LOG_LEVEL=INFO
NEXUS_OBSERVABILITY__LOG_FORMAT=console
